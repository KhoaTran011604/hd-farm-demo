{
  "expo": {
    "name": "HD Farm",
    "slug": "hd-farm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "hdfarms",
    "newArchEnabled": true,
    "owner": "k_tran2001",
    "extra": {
      "eas": {
        "projectId": "ee91e0d5-2b0d-4ed2-99a8-5415ac185c59"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hdfarm.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "HD Farm uses the camera to scan animal QR codes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA"
      ],
      "package": "com.k_tran2001.hdfarm"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "HD Farm uses the camera to scan animal QR codes."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}