{
  "name": "hd-farm",
  "private": true,
  "version": "0.0.1",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "db:generate": "pnpm --filter @hd-farm/db run generate",
    "db:migrate": "pnpm --filter @hd-farm/db run migrate",
    "db:studio": "pnpm --filter @hd-farm/db run studio",
    "db:check": "pnpm --filter @hd-farm/db run check"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "packageManager": "pnpm@10.30.2"
}